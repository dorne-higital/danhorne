# Resend API key — https://resend.com/api-keys
NUXT_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where contact form submissions are delivered
NUXT_CONTACT_EMAIL_TO=hello@danhorne.co.uk

# Sender address. Must be onboarding@resend.dev until a sending domain
# is verified in Resend, e.g. "Dan Horne <hello@danhorne.co.uk>"
NUXT_CONTACT_EMAIL_FROM=Dan Horne <onboarding@resend.dev>
