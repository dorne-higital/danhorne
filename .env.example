# Resend API key — https://resend.com/api-keys
NUXT_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where contact form submissions are delivered
NUXT_CONTACT_EMAIL_TO=hello@danhorne.co.uk

# Sender address. Must be onboarding@resend.dev until a sending domain
# is verified in Resend, e.g. "Dan Horne <hello@danhorne.co.uk>"
NUXT_CONTACT_EMAIL_FROM=Dan Horne <onboarding@resend.dev>

# --- CMS (content-blocks) --------------------------------------------------

# Supabase project — Settings > API in the Supabase dashboard.
NUXT_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Service role key — server-only, never expose this to the client. Used for
# all direct DB/Storage access (server/utils/supabase.ts) AND by @nuxtjs/supabase
# for admin-level auth operations (invite/ban users) — same key, same project.
NUXT_SUPABASE_SERVICE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Admin auth (Supabase Auth, via @nuxtjs/supabase) ----------------------
# These two are PUBLIC (safe to ship to the browser) — same Supabase project
# as above, different key. Settings > API > "anon" / "publishable" key.
NUXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NUXT_PUBLIC_SUPABASE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
